---
import BaseLayout from '../../layouts/BaseLayout.astro';
import IssuePage from '../../components/IssuePage.astro';
import { issue } from '../../data/site';

export function getStaticPaths() {
  return [{ params: { slug: issue.slug } }];
}

const { slug } = Astro.params;
if (slug !== issue.slug) return Astro.redirect('/');
---
<BaseLayout
  title={`macOS App Digest — ${issue.date}`}
  description={`Issue ${issue.number} of macOS App Digest.`}
>
  <IssuePage />
</BaseLayout>
