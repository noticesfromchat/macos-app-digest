---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/AppCard.astro';

export async function getStaticPaths() {
  const apps = await getCollection('apps');
  const tags = [...new Set(apps.flatMap((entry) => entry.data.tags))].sort();

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      apps: apps.filter((entry) => entry.data.tags.includes(tag))
    }
  }));
}

const { tag, apps } = Astro.props;
const tagLabels: Record<string, string> = {
  ai: 'AI',
  airdrop: 'AirDrop',
  ios: 'iOS',
  menubar: 'Menu Bar',
  'open-source': 'Open Source'
};
const title = tagLabels[tag] ?? tag
  .split('-')
  .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
  .join(' ');
---
<BaseLayout
  title={`${title} Mac Apps — App Waypoint`}
  description={`Browse Mac apps tagged ${title}.`}
>
  <section class="archive-page tag-page">
    <p class="eyebrow">Browse by tag</p>
    <h1>{title}</h1>
    <p class="dek">Mac apps selected for their relevance to {title.toLowerCase()} workflows.</p>
    <div class="grid">
      {apps.map((entry) => <AppCard app={entry.data} />)}
    </div>
  </section>
</BaseLayout>
