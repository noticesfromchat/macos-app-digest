---
import type { CollectionEntry } from 'astro:content';
import AppCard from './AppCard.astro';
import ReadingCard from './ReadingCard.astro';

type Issue = CollectionEntry<'issues'>['data'];
type AppEntry = CollectionEntry<'apps'>;

const {
  homepage = false,
  issue,
  appEntries
} = Astro.props as {
  homepage?: boolean;
  issue: Issue;
  appEntries: AppEntry[];
};

const appsById = new Map(appEntries.map((entry) => [entry.id, entry.data]));
const issueLabel = String(Number(issue.number)).padStart(2, '0');
---

<article class:list={['issue', { 'is-homepage': homepage }]}>
  <header class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Current Issue</p>
      <h1>{issue.date}</h1>
      <p class="date">Issue {issueLabel}</p>
      <div class="hero-rule" aria-hidden="true">
        <svg viewBox="0 0 104 14" role="presentation">
          <path d="M1 7c4-6 8 6 12 0s8 6 12 0 8 6 12 0 8 6 12 0 8 6 12 0 8 6 12 0 8 6 12 0 8 6 12 0" />
        </svg>
      </div>
      <p class="dek">{issue.dek}</p>
      <div class="hero-actions">
        <a class="button" href="#new-discoveries">Start Reading <span aria-hidden="true">→</span></a>
        {homepage && <a class="button secondary" href="/archive/">Past Issues</a>}
      </div>
    </div>
    <div class="harbor-artwork" aria-hidden="true">
      <img class="harbor-artwork-light" src="/harbor-hero.png" alt="" width="1536" height="1024" />
      <img class="harbor-artwork-dark" src="/harbor-hero-dark.png" alt="" width="1536" height="1024" />
    </div>
  </header>

  {issue.sections.map((section, index) => (
    <section id={index === 0 ? 'new-discoveries' : undefined} class="section">
      <div class="section-heading">
        <p class="eyebrow">{section.eyebrow}</p>
        <h2>{section.title}</h2>
      </div>
      <div class="grid">
        {section.apps.map((appId) => {
          const app = appsById.get(appId);
          return app ? <AppCard app={app} /> : null;
        })}
      </div>
    </section>
  ))}

  <div class="content-divider" aria-hidden="true">
    <svg viewBox="0 0 1200 128" role="presentation">
      <path class="divider-route" pathLength="100" d="M-28 68C95 68 120 33 220 44c91 10 33 76 112 73 61-2 11-88 91-89 74-1 66 72 143 65 80-8 34-66 119-70 81-4 58 83 151 78 89-5 70-67 154-62 74 5 83 43 161 39" />
      <g class="divider-pin" transform="translate(1138 48) scale(2.05)">
        <path d="M20 10c0 5-8 12-8 12S4 15 4 10a8 8 0 1 1 16 0Z" />
        <circle cx="12" cy="10" r="3" />
      </g>
    </svg>
  </div>

  <section class="section video-section">
    <div class="section-heading">
      <p class="eyebrow">Video of the Week</p>
      <h2>{issue.video.title}</h2>
    </div>
    <article class="card feature-card">
      <p><strong>Creator:</strong> {issue.video.creator}</p>
      <p>{issue.video.description}</p>
      <a href={issue.video.url} target="_blank" rel="noreferrer">Watch on YouTube</a>
    </article>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Weekend Reading</p>
      <h2>Three reads for Mac context</h2>
    </div>
    <div class="grid">
      {issue.readings.map((reading) => <ReadingCard reading={reading} />)}
    </div>
  </section>

  <section class="note">
    <h2>Source Notes</h2>
    <p>This issue was selected from the following sources, with every app homepage checked before publishing.</p>
    <ul>
      {issue.sourceNotes.map((note) => <li>{note}</li>)}
    </ul>
  </section>
</article>
