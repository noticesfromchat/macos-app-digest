---
import type { CollectionEntry } from 'astro:content';
import AppCard from './AppCard.astro';
import ReadingCard from './ReadingCard.astro';

type Issue = CollectionEntry<'issues'>['data'];
type AppEntry = CollectionEntry<'apps'>;

const {
  homepage = false,
  issue,
  appEntries
} = Astro.props as {
  homepage?: boolean;
  issue: Issue;
  appEntries: AppEntry[];
};

const appsById = new Map(appEntries.map((entry) => [entry.id, entry.data]));
---

<article class:list={['issue', { 'is-homepage': homepage }]}>
  <header class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Current Issue</p>
      <h1>Issue {issue.number}</h1>
      <p class="date">{issue.date}</p>
      <div class="hero-rule" aria-hidden="true"><span>〰</span></div>
      <p class="dek">{issue.dek}</p>
      <div class="hero-actions">
        <a class="button" href="#new-discoveries">Start Reading <span aria-hidden="true">→</span></a>
        {homepage && <a class="button secondary" href="/archive/">Past Issues</a>}
      </div>
    </div>
    <div class="harbor-artwork" aria-hidden="true">
      <img src="/harbor-hero.svg" alt="" width="900" height="470" />
    </div>
  </header>

  {homepage && (
    <div class="harbor-values" aria-label="App Waypoint values">
      <div><span class="value-icon">≋</span><p><strong>Handpicked</strong>Carefully selected apps and tools worth your time.</p></div>
      <div><span class="value-icon">⌖</span><p><strong>Practical</strong>Real-world recommendations for Mac users.</p></div>
      <div><span class="value-icon">♜</span><p><strong>Independent</strong>Unaffiliated, unbiased, and focused on quality.</p></div>
    </div>
  )}

  {issue.sections.map((section, index) => (
    <section id={index === 0 ? 'new-discoveries' : undefined} class="section">
      <div class="section-heading">
        <p class="eyebrow">{section.eyebrow}</p>
        <h2>{section.title}</h2>
      </div>
      <div class="grid">
        {section.apps.map((appId) => {
          const app = appsById.get(appId);
          return app ? <AppCard app={app} /> : null;
        })}
      </div>
    </section>
  ))}

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Video of the Week</p>
      <h2>{issue.video.title}</h2>
    </div>
    <article class="card feature-card">
      <p><strong>Creator:</strong> {issue.video.creator}</p>
      <p>{issue.video.description}</p>
      <a href={issue.video.url} target="_blank" rel="noreferrer">Watch on YouTube</a>
    </article>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Weekend Reading</p>
      <h2>Three reads for Mac context</h2>
    </div>
    <div class="grid">
      {issue.readings.map((reading) => <ReadingCard reading={reading} />)}
    </div>
  </section>

  <section class="note">
    <h2>Source Notes</h2>
    <p>This issue was selected from the following sources, with every app homepage checked before publishing.</p>
    <ul>
      {issue.sourceNotes.map((note) => <li>{note}</li>)}
    </ul>
  </section>
</article>
