---
import type { CollectionEntry } from 'astro:content';

type AppEntry = CollectionEntry<'apps'>;
type Pick = CollectionEntry<'issues'>['data']['editorsPicks'][number];

const {
  picks,
  appsById
} = Astro.props as {
  picks: Pick[];
  appsById: Map<string, AppEntry['data']>;
};
---

{picks.length > 0 && (
  <section class="editors-pick" aria-labelledby="editors-pick-title">
    <header class="editors-pick-heading">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="m12 3.4 2.28 4.62 5.1.74-3.69 3.6.87 5.08L12 15.04l-4.56 2.4.87-5.08-3.69-3.6 5.1-.74L12 3.4Z" />
      </svg>
      <h2 id="editors-pick-title">Editor’s Pick</h2>
      <p>One app that stood out to me this week.</p>
    </header>

    <div class="editors-pick-list">
      {picks.map((pick) => {
        const app = appsById.get(pick.app);
        if (!app) return null;

        return (
          <article class="editors-pick-entry">
            <div class="editors-pick-copy">
              <h3>{app.name}</h3>
              <p class="editors-pick-summary">{app.description}</p>
              <p class="editors-pick-note">{pick.note}</p>
            </div>
            <div class="editors-pick-reasons">
              <h4>Why I picked it</h4>
              <ul>
                {pick.why.map((reason) => <li>{reason}</li>)}
              </ul>
              <a href={app.homepage} target="_blank" rel="noreferrer">
                Visit {new URL(app.homepage).hostname.replace(/^www\./, '')}
                <span aria-hidden="true">→</span>
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </section>
)}
